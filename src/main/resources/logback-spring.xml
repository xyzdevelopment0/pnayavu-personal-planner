<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="applicationName" source="spring.application.name"
                    defaultValue="personal-planner"/>

    <property name="logPath" value="${LOG_PATH:-logs}"/>
    <property name="rootLogLevel" value="${ROOT_LOG_LEVEL:-INFO}"/>
    <property name="appLogLevel" value="${APP_LOG_LEVEL:-INFO}"/>
    <property name="sqlLogLevel" value="${SQL_LOG_LEVEL:-DEBUG}"/>
    <property name="sqlBindLogLevel" value="${SQL_BIND_LOG_LEVEL:-TRACE}"/>
    <property name="maxHistory" value="${LOG_MAX_HISTORY:-14}"/>
    <property name="maxFileSize" value="${LOG_MAX_FILE_SIZE:-10KB}"/>
    <property name="totalSizeCap" value="${LOG_TOTAL_SIZE_CAP:-1GB}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logPath}/${applicationName}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${logPath}/archive/${applicationName}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${maxFileSize}</maxFileSize>
            <maxHistory>${maxHistory}</maxHistory>
            <totalSizeCap>${totalSizeCap}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="com.maximovich.planner" level="${appLogLevel}"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate.SQL" level="${sqlLogLevel}"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="${sqlBindLogLevel}"/>

    <root level="${rootLogLevel}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
